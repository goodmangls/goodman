# ===========================================
# GOODMAN GLS Partner Portal - Environment Variables
# ===========================================

# Database (PostgreSQL - Neon recommended)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# NextAuth.js Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Resend API Key (Email Service)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email addresses
CONTACT_EMAIL_TO=contact@goodmangls.com
CONTACT_EMAIL_FROM=noreply@goodmangls.com

# /api/contact 가드 (Origin/Referer 화이트리스트)
# - production 에서는 콤마 구분 origin 리스트 등록 필수 (예: https://goodman-gls.vercel.app)
# - preview 는 VERCEL_ENV=preview + VERCEL_URL 으로 동적 허용
# - development 는 http://localhost:3000 자동 허용
ALLOWED_ORIGINS=

# /api/contact rate limit (IP-based sliding window)
# - 환경별 조정 가능, 미설정 시 default 사용
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000

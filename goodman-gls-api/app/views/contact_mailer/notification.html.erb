<h2>New Contact Message</h2>
<table style="border-collapse:collapse;width:100%;max-width:500px;">
  <tr><td style="padding:8px;font-weight:bold;color:#666;">Name</td><td style="padding:8px;"><%= @msg.name %></td></tr>
  <tr><td style="padding:8px;font-weight:bold;color:#666;">Email</td><td style="padding:8px;"><%= @msg.email %></td></tr>
  <tr><td style="padding:8px;font-weight:bold;color:#666;">Company</td><td style="padding:8px;"><%= @msg.company %></td></tr>
  <tr><td style="padding:8px;font-weight:bold;color:#666;">Phone</td><td style="padding:8px;"><%= @msg.phone %></td></tr>
  <tr><td style="padding:8px;font-weight:bold;color:#666;">Subject</td><td style="padding:8px;"><%= @msg.subject %></td></tr>
</table>
<h3>Message</h3>
<p style="white-space:pre-wrap;background:#f5f5f5;padding:16px;border-radius:8px;"><%= @msg.message %></p>
<p style="color:#999;font-size:12px;">Received at: <%= @msg.created_at %></p>
